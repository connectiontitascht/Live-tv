rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'connection.titascht@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function isNumeric(val) {
      return val is int || val is float;
    }

    // Channels
    match /channels/{channelId} {
      allow read: if true; // Everyone can read channels
      allow create, update: if isAdmin() && isValidChannel(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidChannel(data) {
      return data.keys().hasAll(['name', 'url', 'order'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.url is string && data.url.size() > 0 && data.url.size() <= 500
        && isNumeric(data.order)
        && (!('logo' in data) || (data.logo is string && data.logo.size() <= 500));
    }

    // Configs
    match /configs/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Presence
    match /presence/{presenceId} {
      allow read: if true;
      allow create, update: if isValidId(presenceId) && isValidPresence(request.resource.data);
      allow delete: if isValidId(presenceId);
    }

    function isValidPresence(data) {
      return data.keys().hasAll(['lastActive'])
        && isNumeric(data.lastActive)
        && (!('viewingChannel' in data) || (data.viewingChannel is string && data.viewingChannel.size() <= 100));
    }
  }
}
