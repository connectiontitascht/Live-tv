{
  "entities": {
    "channel": {
      "title": "Channel",
      "description": "A TV channel available for streaming",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the channel"
        },
        "url": {
          "type": "string",
          "description": "M3U8 streaming URL"
        },
        "logo": {
          "type": "string",
          "description": "URL to the channel logo"
        },
        "order": {
          "type": "number",
          "description": "Display order of the channel"
        }
      },
      "required": ["name", "url", "order"]
    },
    "config": {
      "title": "Config",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "initialAdDuration": {
          "type": "number",
          "description": "Duration of the initial ad in seconds"
        },
        "hourlyAdInterval": {
          "type": "number",
          "description": "Interval for recurring ads in seconds"
        },
        "adVideoUrl": {
          "type": "string",
          "description": "URL of the advertisement video"
        }
      }
    },
    "admin": {
      "title": "Admin",
      "description": "A user with administrative privileges",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "Email address of the admin"
        }
      },
      "required": ["email"]
    },
    "presence": {
      "title": "Presence",
      "description": "Active visitor session for real-time occupancy counting",
      "type": "object",
      "properties": {
        "lastActive": {
          "type": "number",
          "description": "Epoch timestamp when the user was last active"
        },
        "viewingChannel": {
          "type": "string",
          "description": "Optional name of the channel the user is currently viewing"
        }
      },
      "required": ["lastActive"]
    }
  },
  "firestore": {
    "/channels/{channelId}": {
      "schema": "channel",
      "description": "List of available TV channels"
    },
    "/configs/global": {
      "schema": "config",
      "description": "Global settings for the app"
    },
    "/admins/{userId}": {
      "schema": "admin",
      "description": "Collection of admin users by their UID"
    },
    "/presence/{presenceId}": {
      "schema": "presence",
      "description": "Session tracking for online visitors count"
    }
  }
}
